#include<iostream>
#include<vector>
#include <algorithm>
using namespace std;
int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        long long int n,a,b;
        cin>>n>>a>>b;
        long long int ans1=n*a;
        long long int ans2=(n/3)*b;
        if(n%3!=0)
          ans2+=min((n%3)*a,b);
          
        cout<<min(ans1,ans2)<<endl;
           
          
    }
}