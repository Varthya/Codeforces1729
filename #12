#include<iostream>
#include<vector>
#include <algorithm>
using namespace std;
int main()
{

    int t;
    cin>>t;
    while(t--)
    {
    string s;
    cin>>s;
    long long int ans=4;
    for(int i=0;i<3;i++)
    {
    int num1=s[i]-'0';
    int num2=s[i+1]-'0';
      if(num2==0)
        num2+=10;
        
      if(num1==0)
      num1+=10;
         
     ans+=abs(num2-num1);  
    }
    int num=s[0]-'0';
    if(num==0)
       num+=10;
       
      num--;
      ans+=num;
        cout<<ans<<endl;
        
    }
}