#include<iostream>
#include<vector>
#include <algorithm>
using namespace std;
int main()
{

    int t;
    cin>>t;
    while(t--)
    {
     int n;
     cin>>n;
     int ma=0;
     int mi=10;
     for(int i=0;i<n;i++)
     {
      int x;
      cin>>x;
      ma=max(ma,x);
      mi=min(mi,x);
     }
     cout<<(ma+1-mi)<<endl;
    }
}