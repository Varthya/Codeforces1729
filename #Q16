#include<iostream>
#include<vector>
#include <algorithm>
using namespace std;
int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        long long int n;
        cin>>n;
        int two_count=0;
        int three_count=0;
        while(n%2==0)
        {
            two_count++;
            n/=2;
        }
        while(n%3==0)
        {
            three_count++;
            n=n/3;
        }
        if(n==1&&three_count>=two_count)
        {
        cout<<(three_count+(three_count-two_count))<<endl;
        }
        else
        cout<<-1<<endl;
    }
}