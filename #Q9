#include<iostream>
#include<vector>
#include <algorithm>
using namespace std;
int main()
{

    int t;
    cin>>t;
    while(t--)
    {
        int n,m,d;
        cin>>n>>m>>d;
        int p=d/m;
        int g=p+1;
        int ans=(n/g);
        if(n%g!=0)
           ans++;
           
        cout<<ans<<endl;   
    }
}